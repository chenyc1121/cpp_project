# ==============================
# Default line endings
# ==============================
* text=auto eol=lf

# C / C++
*.c     text eol=lf
*.cc    text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.hpp   text eol=lf
*.cxx   text eol=lf

# Qt / CMake
CMakeLists.txt text eol=lf
*.cmake        text eol=lf
*.pro          text eol=lf
*.pri          text eol=lf
*.ui           text eol=lf

# Scripts
*.sh   text eol=lf
*.bash text eol=lf
*.zsh  text eol=lf

# Text files
*.txt  text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.xml  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.bmp  binary
*.ico  binary
*.zip  binary
*.7z   binary
*.rar  binary
*.pdf  binary

# IDE files
*.user text
.qtcreator/ -text

# Build artifacts (safe ignore hint for git attributes only)
*.exe binary
*.out binary
*.o   binary
